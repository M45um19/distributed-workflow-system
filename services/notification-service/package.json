{
  "name": "notification-service",
  "version": "1.0.0",
  "type": "module",
  "description": "TaskFlow Notification Service - Handles real-time notifications via Socket.io and Kafka event consumption.",
  "main": "dist/server.js",
  "scripts": {
    "dev:server": "nodemon --watch src --exec tsx src/server.ts",
    "dev:worker": "nodemon --watch src --exec tsx src/worker.ts",
    "build": "tsc",
    "start:server": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint .",
    "test": "jest"
  },
  "keywords": [
    "taskflow",
    "microservice",
    "notification-service",
    "socket.io",
    "kafka"
  ],
  "author": "Naim Istiak",
  "license": "MIT",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.5.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.10",
    "eslint": "^9.7.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.59.2"
  }
}
